{
  "name": "personal-organizer-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build:web": "npm --prefix ../web run build",
    "ci:build": "npm install --include=dev && npm --prefix ../web install --include=dev && npm --prefix ../web run build",
    "predeploy": "npm run build:web",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply personal-organizer --local",
    "migrate:remote": "wrangler d1 migrations apply personal-organizer --remote"
  },
  "dependencies": {
    "@block65/webcrypto-web-push": "^1.0.2",
    "hono": "^4.12.18"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260616.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.100.0"
  }
}
