# Wzór zmiennych lokalnych dla `wrangler dev`. Skopiuj do `.dev.vars` i ustaw własne wartości.
# .dev.vars jest w .gitignore — NIE commituj prawdziwych wartości.

# Token dostępu do API (front wysyła go w nagłówku Authorization).
APP_TOKEN="zmien-mnie-na-dlugi-losowy-ciag"

# Web Push (VAPID). Wygeneruj: `npx web-push generate-vapid-keys --json`.
VAPID_SUBJECT="mailto:twoj@email.example"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
